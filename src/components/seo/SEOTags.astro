---
import { SEO } from "astro-seo";
import { SITE_URL } from "@/data/config";
import type { HeadTags } from "@/utils/types/HeadTags";

type Props = HeadTags & { ogImage: string };

const { title, description, noindex, ogImage } = Astro.props;

const DEFAULT_TITLE_PAGE = "Zine El Abidine Moualhi - Portfolio";
const DEFAULT_DESCRIPTION_PAGE = "A minimal portfolio of a Junior DevOps Engineer.";
const DEFAULT_URL_SITE = SITE_URL;

const openGraph = {
  title: title || DEFAULT_TITLE_PAGE,
  type: "website",
  image: ogImage || "/opengraph-image.jpg",
  alt: description  ||"Junior DevOps Engineer & part-time Tomfoolery Expert's portfolio",
  url: DEFAULT_URL_SITE,
  description: description|| DEFAULT_DESCRIPTION_PAGE,
};
---

<head>
  <SEO
    charset="UTF-8"
    title={title || DEFAULT_TITLE_PAGE}
    description={description || DEFAULT_DESCRIPTION_PAGE}
    noindex={noindex || false}
    openGraph={{
      basic: {
        title: openGraph.title,
        type: openGraph.type,
        image: openGraph.image,
      },
      image: {
        alt: openGraph.alt,
      },
    }}
    twitter={{
      creator: "@fatnorth",
    }}
    extend={{
      link: [
        { rel: "icon", href: "/favicon.ico" },
        { rel: "sitemap", href: "/sitemap-index.xml" },
      ],
      meta: [
        { name: "viewport", content: "width=device-width, initial-scale=1" },
        { name: "generator", content: Astro.generator },
        {
          name: "twitter:image",
          content: openGraph.image,
        },
        { name: "twitter:card", content: "summary_large_image" },
        { name: "twitter:title", content: openGraph.title },
        { name: "twitter:description", content: openGraph.description },
        { name: "twitter:site", content: "@fatnorth" },
      ],
    }}
  />
</head>
